<odoo>

    <record id="technical_order_reject_wizard_form" model="ir.ui.view">
        <field name="name">technical.order.reject.wizard.form</field>
        <field name="model">technical.order.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Rejection Reason">
                <group>
                    <field name="rejection_reason"/>
                </group>
                <footer>
                    <button name="action_confirm"
                            type="object"
                            string="Confirm"
                            class="btn-primary"/>

                    <button string="Cancel"
                            special="cancel"
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="technical_order_reject_wizard_action" model="ir.actions.act_window">
        <field name="name">Technical Order Rejection</field>
        <field name="res_model">technical.order.reject.wizard</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="technical_order_reject_wizard_form"/>
        <field name="target">new</field>
    </record>

</odoo>